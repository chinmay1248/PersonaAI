# Frontend Environment Configuration Template
# Copy this to .env and fill in your values

# API Configuration
# For development: use local backend
# EXPO_PUBLIC_API_URL=http://localhost:8000/v1
# 
# For production: use deployed backend URL
# EXPO_PUBLIC_API_URL=https://personaai-backend-production-4490.up.railway.app/v1

EXPO_PUBLIC_API_URL=http://localhost:8000/v1
EXPO_PUBLIC_ENV=development

# App Configuration
EXPO_PUBLIC_APP_NAME=PersonaAI
