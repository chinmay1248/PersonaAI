# --- Local Development ---
DATABASE_URL=sqlite:///./personaai.db
REDIS_URL=redis://localhost:6379/0

# --- Auth & Security ---
JWT_SECRET_KEY=change-me-use-a-long-random-string
ENCRYPTION_KEY=generate-with-python-cryptography-fernet
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI Services ---
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1

# --- Environment (set to 'production' on Railway) ---
APP_ENV=development
