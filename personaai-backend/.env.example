# --- Database Configuration ---
# For development with PostgreSQL in docker-compose:
# DATABASE_URL=postgresql://personaai:personaai@localhost:5432/personaai_db
# DB_USER=personaai
# DB_PASSWORD=personaai
# DB_NAME=personaai_db

# For development with SQLite:
DATABASE_URL=sqlite:///./personaai.db

# For production (Railway/Docker): Provide PostgreSQL connection string
# Example: DATABASE_URL=postgresql://user:password@db-host:5432/dbname

# --- Redis Configuration ---
REDIS_URL=redis://localhost:6379/0
# For production: Use managed Redis service
# Example: REDIS_URL=redis://:password@redis-host:6379/0

# --- Auth & Security (REQUIRED) ---
# DO NOT use defaults in production. Generate secure random values:
# Python: from cryptography.fernet import Fernet; Fernet.generate_key().decode()
# Python: import secrets; secrets.token_urlsafe(32)
JWT_SECRET_KEY=change-me-use-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=generate-with-fernet-cryptography-library
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI Services (Optional) ---
# Get API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Pinecone: https://www.pinecone.io/
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1

# --- Environment (development|production) ---
# Set to 'production' when deploying to Railway/production
APP_ENV=development

