# PersonaAI production environment for a self-hosted VPS running Docker Compose + Ollama.
# Copy to .env.production on the server and replace every placeholder before deploy.

# --- Public API endpoint ---
APP_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=ops@example.com

# --- Database ---
DB_USER=personaai
DB_PASSWORD=replace-with-a-long-random-password
DB_NAME=personaai

# --- App security ---
JWT_SECRET_KEY=replace-with-secrets-token-urlsafe-32-or-longer
ENCRYPTION_KEY=replace-with-a-valid-fernet-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Runtime ---
APP_ENV=production

# --- Ollama ---
LLM_PROVIDER=ollama
ENABLE_LLM=true
LLM_BASE_URL=http://ollama:11434/v1
LLM_CHAT_MODEL=llama3.2:3b
LLM_FAST_MODEL=llama3.2:3b
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_API_KEY=

# --- Optional vector storage ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
